rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only these production emails can use the app
    function isAllowedUser() {
      return request.auth != null
        && request.auth.token.email in [
          'alonzorz@gmail.com',
          'swaddlesnaps@gmail.com',
          'moralalon@gmail.com'
        ];
    }

    function isPartnerAEmail() {
      return isAllowedUser()
        && request.auth.token.email == 'alonzorz@gmail.com';
    }

    function isPartnerBEmail() {
      return isAllowedUser()
        && request.auth.token.email in ['swaddlesnaps@gmail.com', 'moralalon@gmail.com'];
    }

    // Helper: is the caller a member of this household?
    function isMember(householdId) {
      return isAllowedUser()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.householdId == householdId;
    }

    // Deny everything by default — only allowed users can do anything
    match /{document=**} {
      allow read, write: if false;
    }

    // User documents — each user can only read/write their own
    match /users/{uid} {
      allow read, write: if isAllowedUser() && request.auth.uid == uid;
    }

    // Household document
    match /households/{householdId} {
      // Any allowlisted user can read — needed for the join-or-create transaction
      // (user doc has householdId: null before first join, so isMember() would fail)
      allow read: if isAllowedUser();

      allow create: if (isPartnerAEmail()
          && request.resource.data.partnerAUid == request.auth.uid)
        || (isPartnerBEmail()
          && request.resource.data.partnerBUid == request.auth.uid);

      allow update: if isMember(householdId)
        || (isPartnerAEmail()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['partnerAUid'])
            && request.resource.data.partnerAUid == request.auth.uid)
        || (isPartnerBEmail()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['partnerBUid'])
            && request.resource.data.partnerBUid == request.auth.uid);

      // Cards — only members
      match /cards/{cardId} {
        allow read: if isMember(householdId);
        allow create: if isMember(householdId);
        allow update: if isMember(householdId);
        allow delete: if isMember(householdId);
      }

      // History — append-only, no update or delete
      match /history/{eventId} {
        allow read: if isMember(householdId);
        allow create: if isMember(householdId);
      }

      // Stats — append-only analytics events
      match /stats/{eventId} {
        allow read: if isMember(householdId);
        allow create: if isMember(householdId);
      }

      // Family memories — both partners can read/write
      match /memories/{memoryId} {
        allow read: if isMember(householdId);
        allow create: if isMember(householdId);
        allow delete: if isMember(householdId);
      }

      // Shared chat — both partners can read/write
      match /chats/{chatId}/messages/{messageId} {
        allow read: if isMember(householdId);
        allow create: if isMember(householdId);
        allow delete: if isMember(householdId); // for compaction
      }
    }

    // Private chats — each user can only access their own
    match /users/{uid}/chats/{chatId}/messages/{messageId} {
      allow read, write: if isAllowedUser() && request.auth.uid == uid;
    }

    // Weekly reports
    match /households/{householdId}/weeklyReports/{reportId} {
      allow read: if isMember(householdId);
    }

    // Personal memories — each user manages their own
    match /users/{uid}/memories/{memoryId} {
      allow read, write: if isAllowedUser() && request.auth.uid == uid;
    }

    // Push notification tokens — each user manages their own
    match /users/{uid}/tokens/{tokenId} {
      allow read, write: if isAllowedUser() && request.auth.uid == uid;
    }
  }
}
